# Root
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=jt_session
DATABASE_URL=postgresql://user:password@localhost:5432/jumatech
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/jumatech
DATABASE_URL_POOLED=postgresql://user:password@localhost:5432/jumatech
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@jumatech.solutions

# Admin credentials (do NOT commit real secrets). Prefer setting ADMIN_PASSWORD_HASH.
# Example: generate a bcrypt hash with `node ./apps/api/scripts/hash-admin-password.js "YourPassword"`
# Then set the resulting hash in ADMIN_PASSWORD_HASH.
ADMIN_EMAIL=
# Either provide ADMIN_PASSWORD_HASH or (less secure) ADMIN_PASSWORD for development only.
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=
